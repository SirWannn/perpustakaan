generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Buku {
  id          Int          @id @default(autoincrement())
  kodeBuku    String
  judul       String
  penulis     String
  tahunTerbit Int?
  stok        Int          @default(0)
  peminjaman  Peminjaman[] // Relasi ke tabel peminjaman
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model User {
  id          Int          @id @default(autoincrement())
  nama        String
  email       String       @unique
  password    String
  createdAt   DateTime     @default(now())
}

model Peminjaman {
  id              Int       @id @default(autoincrement())
  kodePinjam      String    
  namaPeminjam    String    
  kelas           String?   
  
  // 1. Tambahkan tanda tanya (?) pada Int agar datanya diizinkan kosong
  bukuId          Int?      
  
  tenggatWaktu    DateTime
  tanggalPinjam   DateTime  @default(now())
  tanggalKembali  DateTime?
  status          String    @default("Dipinjam")

  // 2. Tambahkan tanda tanya (?) pada Buku dan gunakan onDelete: SetNull
  buku            Buku?     @relation(fields: [bukuId], references: [id], onDelete: SetNull)
}

// Tabel untuk mencatat riwayat login
model RiwayatLogin {
  id        Int      @id @default(autoincrement())
  waktu     DateTime @default(now())
  perangkat String   // Menyimpan browser/device yang digunakan
  ip        String   // Menyimpan alamat IP
  status    String   // "Berhasil" atau "Gagal"
}
